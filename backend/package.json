{
  "name": "medusa-starter-default",
  "version": "0.0.1",
  "description": "A starter for Medusa projects.",
  "author": "Medusa (https://medusajs.com)",
  "license": "MIT",
  "keywords": [
    "sqlite",
    "postgres",
    "typescript",
    "ecommerce",
    "headless",
    "medusa"
  ],
  "scripts": {
    "prebuild": "node ./scripts/check-node-version.js",
    "build": "medusa build",
    "preseed": "node ./scripts/check-node-version.js",
    "seed": "medusa exec ./src/scripts/seed.ts",
    "sync:product-images": "medusa exec ./src/scripts/sync-product-images.ts",
    "premigrate:site-data": "node ./scripts/check-node-version.js",
    "migrate:site-data": "medusa exec ./src/scripts/migrate-site-data.ts",
    "presearch:reindex": "node ./scripts/check-node-version.js",
    "search:reindex": "medusa exec ./src/scripts/reindex-search.ts",
    "prestart": "node ./scripts/check-node-version.js",
    "start": "medusa start",
    "predev": "node ./scripts/check-node-version.js",
    "dev": "medusa develop"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1054.0",
    "@medusajs/admin-sdk": "2.15.3",
    "@medusajs/cli": "2.15.3",
    "@medusajs/file-s3": "2.15.3",
    "@medusajs/framework": "2.15.3",
    "@medusajs/medusa": "2.15.3",
    "dotenv": "^17.4.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@swc/core": "^1.7.28",
    "@types/node": "^20.12.11",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.2.25",
    "prop-types": "^15.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vite": "^5.4.14"
  },
  "engines": {
    "node": ">=20 <23"
  }
}
